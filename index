<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Translater</title>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      min-height: 100vh;
      background: #0f0f13;
      color: #e8e8f0;
      font-family: 'Inter', 'Segoe UI', sans-serif;
      display: flex;
      flex-direction: column;
      align-items: center;
      padding: 48px 16px 80px;
    }

    /* ── Header ── */
    header {
      text-align: center;
      margin-bottom: 36px;
    }
    header h1 {
      font-size: 2.2rem;
      font-weight: 700;
      letter-spacing: -0.03em;
      background: linear-gradient(135deg, #a78bfa, #60a5fa);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
    }
    header p {
      color: #6b6b80;
      font-size: 0.88rem;
      margin-top: 6px;
    }

    /* ── API Key banner ── */
    #key-banner {
      width: 100%;
      max-width: 640px;
      background: #18181f;
      border: 1px solid #2a2a35;
      border-radius: 14px;
      padding: 16px 20px;
      margin-bottom: 20px;
      display: flex;
      gap: 10px;
      align-items: center;
    }
    #key-banner input {
      flex: 1;
      background: #1e1e27;
      border: 1.5px solid #2a2a35;
      border-radius: 8px;
      padding: 10px 14px;
      color: #e8e8f0;
      font-size: 0.88rem;
      outline: none;
      transition: border-color 0.15s;
    }
    #key-banner input:focus { border-color: #a78bfa; }
    #key-banner label { color: #6b6b80; font-size: 0.82rem; white-space: nowrap; }

    /* ── Card ── */
    .card {
      width: 100%;
      max-width: 640px;
      background: #18181f;
      border: 1px solid #2a2a35;
      border-radius: 20px;
      overflow: hidden;
      box-shadow: 0 8px 40px rgba(0,0,0,0.4);
    }

    /* ── Textarea ── */
    .input-area {
      padding: 24px 24px 0;
    }
    textarea {
      width: 100%;
      background: transparent;
      border: none;
      outline: none;
      resize: none;
      font-size: 1.05rem;
      color: #e8e8f0;
      line-height: 1.6;
      font-family: inherit;
    }
    textarea::placeholder { color: #3a3a48; }

    .divider { height: 1px; background: #2a2a35; margin: 16px 0; }

    /* ── Back Thought toggle ── */
    .bt-area { padding: 0 24px 16px; }
    #bt-btn {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      padding: 8px 16px;
      border-radius: 999px;
      border: 1.5px solid #2a2a35;
      background: transparent;
      color: #6b6b80;
      cursor: pointer;
      font-size: 0.85rem;
      font-weight: 500;
      transition: all 0.15s;
      font-family: inherit;
    }
    #bt-btn.active {
      border-color: #a78bfa;
      background: rgba(167,139,250,0.12);
      color: #a78bfa;
    }

    /* ── Language grid ── */
    .lang-area { padding: 0 24px 24px; }
    .lang-label {
      font-size: 0.75rem;
      color: #6b6b80;
      margin-bottom: 12px;
      letter-spacing: 0.05em;
    }
    .lang-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(52px, 1fr));
      gap: 8px;
    }
    .lang-btn {
      padding: 10px 4px;
      border-radius: 10px;
      border: 1.5px solid #2a2a35;
      background: #1e1e27;
      cursor: pointer;
      font-size: 1.4rem;
      text-align: center;
      transition: all 0.12s;
      line-height: 1;
      position: relative;
    }
    .lang-btn:hover { border-color: #3a3a50; background: #22222e; }
    .lang-btn.selected {
      border-color: #60a5fa;
      background: rgba(96,165,250,0.12);
    }
    .lang-btn[title]:hover::after {
      content: attr(title);
      position: absolute;
      bottom: calc(100% + 6px);
      left: 50%;
      transform: translateX(-50%);
      background: #2a2a35;
      color: #e8e8f0;
      font-size: 0.72rem;
      padding: 4px 8px;
      border-radius: 6px;
      white-space: nowrap;
      pointer-events: none;
      z-index: 10;
      font-family: 'Inter', 'Segoe UI', sans-serif;
    }
    #selected-lang-label {
      font-size: 0.8rem;
      color: #60a5fa;
      margin-top: 10px;
      min-height: 1.2em;
    }

    /* ── Go button ── */
    .go-area { padding: 0 24px 24px; }
    #go-btn {
      width: 100%;
      padding: 14px;
      border-radius: 12px;
      border: none;
      background: linear-gradient(135deg, #a78bfa, #60a5fa);
      color: #fff;
      font-size: 0.95rem;
      font-weight: 600;
      cursor: pointer;
      transition: all 0.15s;
      letter-spacing: 0.02em;
      font-family: inherit;
    }
    #go-btn:disabled {
      background: #2a2a35;
      color: #4a4a55;
      cursor: not-allowed;
    }
    #go-btn:not(:disabled):hover { opacity: 0.9; transform: translateY(-1px); }

    /* ── Output ── */
    #output-section { display: none; }
    #output-section.visible { display: block; }
    .output-inner { padding: 24px; }
    .result-main {
      font-size: 1.05rem;
      color: #e8e8f0;
      line-height: 1.7;
    }
    .result-muted {
      font-size: 1rem;
      color: #6b6b80;
      font-style: italic;
      line-height: 1.7;
    }
    .result-truth {
      font-size: 1.05rem;
      color: #e8e8f0;
      line-height: 1.7;
      margin-top: 12px;
    }
    .error-msg { color: #f87171; font-size: 0.9rem; }

    /* ── Loader ── */
    .loader {
      display: inline-block;
      width: 18px; height: 18px;
      border: 2px solid #3a3a48;
      border-top-color: #a78bfa;
      border-radius: 50%;
      animation: spin 0.7s linear infinite;
      vertical-align: middle;
      margin-right: 8px;
    }
    @keyframes spin { to { transform: rotate(360deg); } }
  </style>
</head>
<body>

  <header>
    <h1>Translater</h1>
    <p>Translate or reveal the hidden truth</p>
  </header>

  <!-- API Key input -->
  <div id="key-banner">
    <label for="api-key">Gemini API Key</label>
    <input type="password" id="api-key" placeholder="AIza..." autocomplete="off" />
  </div>

  <!-- Main card -->
  <div class="card">

    <!-- Text input -->
    <div class="input-area">
      <textarea id="text-input" rows="4" placeholder="Enter a message..."></textarea>
    </div>

    <div class="divider"></div>

    <!-- Back Thought -->
    <div class="bt-area">
      <button id="bt-btn" onclick="toggleBT()">🔎 Back Thought</button>
    </div>

    <!-- Language grid -->
    <div class="lang-area">
      <div class="lang-label">TARGET LANGUAGE</div>
      <div class="lang-grid" id="lang-grid"></div>
      <div id="selected-lang-label"></div>
    </div>

    <!-- Go -->
    <div class="go-area">
      <button id="go-btn" disabled onclick="handleGo()">Go</button>
    </div>

    <!-- Output -->
    <div id="output-section">
      <div class="divider"></div>
      <div class="output-inner" id="output-inner"></div>
    </div>

  </div>

  <script>
    const LANG_EMOJIS = {
      "🇬🇧": "English", "🇫🇷": "French", "🇸🇦": "Arabic",
      "🇯🇵": "Japanese", "🇮🇹": "Italian", "🇩🇪": "German",
      "🇪🇸": "Spanish", "🇷🇺": "Russian", "🇲🇦": "Maghrebi dialect",
      "🇵🇹": "Portuguese", "🇳🇱": "Dutch", "🇰🇷": "Korean",
      "🇨🇳": "Chinese", "🇷🇴": "Romanian", "🇵🇱": "Polish",
      "🇨🇿": "Czech", "🇧🇬": "Bulgarian", "🇭🇺": "Hungarian",
      "🇭🇷": "Croatian", "🇻🇳": "Vietnamese", "🇹🇭": "Thai",
    };
    const LANG_TO_EMOJI = Object.fromEntries(Object.entries(LANG_EMOJIS).map(([k,v])=>[v,k]));
    const SUPPORTED = Object.values(LANG_EMOJIS).join(", ");

    let selectedLang = null;
    let backThought = false;

    // Build language grid
    const grid = document.getElementById("lang-grid");
    Object.entries(LANG_EMOJIS).forEach(([emoji, lang]) => {
      const btn = document.createElement("button");
      btn.className = "lang-btn";
      btn.title = lang;
      btn.dataset.emoji = emoji;
      btn.textContent = emoji;
      btn.onclick = () => selectLang(emoji);
      grid.appendChild(btn);
    });

    // Text input listener
    document.getElementById("text-input").addEventListener("input", updateGoBtn);

    function selectLang(emoji) {
      if (selectedLang === emoji) {
        selectedLang = null;
      } else {
        selectedLang = emoji;
      }
      document.querySelectorAll(".lang-btn").forEach(b => {
        b.classList.toggle("selected", b.dataset.emoji === selectedLang);
      });
      const label = document.getElementById("selected-lang-label");
      label.textContent = selectedLang ? `→ ${LANG_EMOJIS[selectedLang]}` : "";
      updateGoBtn();
    }

    function toggleBT() {
      backThought = !backThought;
      document.getElementById("bt-btn").classList.toggle("active", backThought);
      updateGoBtn();
    }

    function updateGoBtn() {
      const text = document.getElementById("text-input").value.trim();
      const active = text && (selectedLang || backThought);
      document.getElementById("go-btn").disabled = !active;
    }

    async function callGemini(text, targetLang, mode) {
      const apiKey = document.getElementById("api-key").value.trim();
      if (!apiKey) throw new Error("Please enter your Gemini API key.");

      let prompt;
      if (mode === "translate" && targetLang) {
        prompt =
          `Do two things at once:\n` +
          `1. Detect the language of this text from this list ONLY: ${SUPPORTED}. If not in list, write UNKNOWN.\n` +
          `2. Translate the text to ${targetLang}.\n\n` +
          `Reply in this exact format (2 lines only):\n` +
          `LANG: <detected language>\n` +
          `RESULT: <translation>\n\n` +
          `Text: ${text}`;
      } else {
        const langInstruction = targetLang
          ? `in ${targetLang}`
          : "in the same language as the original text";
        prompt =
          `Do two things at once:\n` +
          `1. Detect the language of this text from this list ONLY: ${SUPPORTED}. If not in list, write UNKNOWN.\n` +
          `2. As a humorous Discord bot, reveal the hidden true meaning of this message based on Discord/gaming clichés. Reply ${langInstruction}, short and funny.\n\n` +
          `Reply in this exact format (2 lines only):\n` +
          `LANG: <detected language>\n` +
          `RESULT: <hidden truth>\n\n` +
          `Text: ${text}`;
      }

      const res = await fetch(
        `https://generativelanguage.googleapis.com/v1beta/models/gemini-2.5-flash:generateContent?key=${apiKey}`,
        {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({
            contents: [{ parts: [{ text: prompt }] }],
            generationConfig: { temperature: 0.7 }
          })
        }
      );

      if (!res.ok) {
        const err = await res.json();
        throw new Error(err.error?.message ?? "Gemini API error");
      }

      const data = await res.json();
      const raw = data.candidates?.[0]?.content?.parts?.[0]?.text ?? "";
      const lines = raw.trim().split("\n");

      let sourceLang = null;
      let result = "";

      for (const line of lines) {
        if (line.startsWith("LANG:")) {
          const detected = line.replace("LANG:", "").trim();
          for (const lang of Object.values(LANG_EMOJIS)) {
            if (lang.toLowerCase() === detected.toLowerCase()) {
              sourceLang = lang;
              break;
            }
          }
        } else if (line.startsWith("RESULT:")) {
          result = line.replace("RESULT:", "").trim();
        }
      }

      return { sourceLang, result };
    }

    function setOutput(html) {
      const section = document.getElementById("output-section");
      document.getElementById("output-inner").innerHTML = html;
      section.classList.add("visible");
    }

    function setLoading(on) {
      const btn = document.getElementById("go-btn");
      btn.disabled = on;
      btn.innerHTML = on ? '<span class="loader"></span>Processing...' : "Go";
    }

    async function handleGo() {
      const text = document.getElementById("text-input").value.trim();
      if (!text) return;

      setLoading(true);
      document.getElementById("output-section").classList.remove("visible");

      try {
        const targetLang = selectedLang ? LANG_EMOJIS[selectedLang] : null;

        // ── Truth only ──
        if (backThought && !selectedLang) {
          const { sourceLang, result } = await callGemini(text, null, "truth");
          if (!sourceLang) { setOutput(`<p class="error-msg">❌ Language not supported.</p>`); return; }
          setOutput(`<p class="result-main">${result}</p>`);
        }

        // ── Translation only ──
        else if (!backThought && selectedLang) {
          const { sourceLang, result } = await callGemini(text, targetLang, "translate");
          if (!sourceLang) { setOutput(`<p class="error-msg">❌ Language not supported.</p>`); return; }
          const emoji = LANG_TO_EMOJI[sourceLang] ?? "🏳️";
          if (sourceLang === targetLang) {
            setOutput(`<p class="result-muted">${emoji} Already in ${sourceLang}.</p>`);
          } else {
            setOutput(`<p class="result-main">${emoji} ${result}</p>`);
          }
        }

        // ── Truth + translation ──
        else if (backThought && selectedLang) {
          const { sourceLang, result: truthText } = await callGemini(text, null, "truth");
          if (!sourceLang) { setOutput(`<p class="error-msg">❌ Language not supported.</p>`); return; }
          const emoji = LANG_TO_EMOJI[sourceLang] ?? "🏳️";

          if (sourceLang === targetLang) {
            setOutput(
              `<p class="result-muted">${emoji} Already in ${sourceLang}.</p>` +
              `<p class="result-truth">${truthText}</p>`
            );
          } else {
            const { result: translatedTruth } = await callGemini(truthText, targetLang, "translate");
            setOutput(`<p class="result-main">${emoji} ${translatedTruth}</p>`);
          }
        }

      } catch (e) {
        setOutput(`<p class="error-msg">❌ ${e.message}</p>`);
      } finally {
        setLoading(false);
        updateGoBtn();
      }
    }
  </script>
</body>
</html>

